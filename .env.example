# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real credentials.

# Base URL of any OpenAI-compatible or Anthropic-native endpoint.
# Examples:
#   https://api.openai.com
#   https://api.anthropic.com
#   https://api.deepseek.com
#   https://your-own-proxy.example.com
PROXY_BASE_URL=

# Two API keys for tests (can be the same).
# LEGACY: used for non-cache tests.
PROXY_KEY_LEGACY=

# CACHEABLE: used for cache.test.ts; this key/plan must allow
# `cache_control` to pass through to the upstream Anthropic API.
PROXY_KEY_CACHEABLE=
